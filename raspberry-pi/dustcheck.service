[Unit]
Description=DustCheck Air Quality Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/dustcheck
ExecStart=/usr/bin/python3 -u monitor.py
Restart=always
RestartSec=10
StandardOutput=append:/home/pi/dustcheck/monitor.log
StandardError=append:/home/pi/dustcheck/monitor.log

[Install]
WantedBy=multi-user.target
